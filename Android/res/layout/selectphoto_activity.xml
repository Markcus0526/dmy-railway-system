<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
				android:layout_width="fill_parent"
				android:layout_height="fill_parent" android:background="#00000000" android:id="@+id/parent_layout">

	<LinearLayout
			android:orientation="horizontal"
			android:layout_width="400px"
			android:layout_height="320px" android:layout_centerInParent="true" android:id="@+id/back_layout"
			android:background="@drawable/popupdlg_back">
		<LinearLayout
				android:orientation="vertical"
				android:layout_width="0dp"
				android:layout_height="fill_parent" android:layout_weight="15">
		</LinearLayout>
		<LinearLayout
				android:orientation="vertical"
				android:layout_width="0dp"
				android:layout_height="fill_parent" android:layout_weight="450">
			<LinearLayout
					android:orientation="vertical"
					android:layout_width="fill_parent"
					android:layout_height="0dp" android:layout_weight="20">
			</LinearLayout>
			<RelativeLayout
					android:layout_width="fill_parent"
					android:layout_height="0dp" android:layout_weight="30">
				<TextView
						android:layout_width="fill_parent"
						android:layout_height="fill_parent"
						android:id="@+id/txtTakeAPhoto" android:layout_alignParentLeft="false"
						android:layout_alignParentTop="false" android:textSize="22px"
						android:gravity="center" android:background="@drawable/btn_lightgray"
						android:textColor="@android:color/black" android:layout_weight="30"
						android:layout_alignParentBottom="false" android:layout_alignParentRight="false"/>
				<Button
						android:layout_width="fill_parent"
						android:layout_height="fill_parent"
						android:id="@+id/btnTakePhoto" android:background="@drawable/btn_empty"
						android:text="@string/STR_TAKE_PHOTO"
						android:textColor="#FF000000" android:textSize="28px"/>
			</RelativeLayout>
			<LinearLayout
					android:orientation="vertical"
					android:layout_width="fill_parent"
					android:layout_height="0dp" android:layout_weight="15">
			</LinearLayout>
			<RelativeLayout
					android:layout_width="fill_parent"
					android:layout_height="0dp" android:layout_weight="30">
				<TextView
						android:layout_width="fill_parent"
						android:layout_height="fill_parent"
						android:id="@+id/txtSelectFromAlbum" android:layout_alignParentTop="false"
						android:background="@drawable/btn_lightgray"
						android:textSize="22px" android:gravity="center" android:textColor="@android:color/black"
						android:layout_weight="30"
						android:layout_alignParentLeft="false" android:layout_alignParentBottom="false"
						android:layout_alignParentRight="false"/>
				<Button
						android:layout_width="fill_parent"
						android:layout_height="fill_parent"
						android:id="@+id/btnSelImage" android:background="@drawable/btn_empty"
						android:text="@string/STR_SELECT_IMAGE"
						android:textColor="#FF000000" android:textSize="28px"/>
			</RelativeLayout>
			<LinearLayout
					android:orientation="vertical"
					android:layout_width="fill_parent"
					android:layout_height="0dp" android:layout_weight="15">
			</LinearLayout>
			<RelativeLayout
					android:layout_width="fill_parent"
					android:layout_height="0dp" android:layout_weight="30">
				<TextView
						android:layout_width="fill_parent"
						android:layout_height="fill_parent"
						android:id="@+id/txtCancel"
						android:layout_alignRight="@+id/txtTakeAPhoto" android:gravity="center"
						android:background="@drawable/btn_darkgray" android:textSize="22px" android:textColor="#ffffff"
						android:layout_weight="30"
						android:layout_alignParentTop="true" android:layout_alignParentLeft="true"
						android:layout_alignParentBottom="true" android:layout_alignParentRight="true"
						android:singleLine="false"/>
				<Button
						android:layout_width="fill_parent"
						android:layout_height="fill_parent"
						android:id="@+id/btnCancel" android:background="@drawable/btn_empty"
						android:text="@string/STR_CANCEL" android:textColor="#ffffffff" android:textSize="28px"/>
			</RelativeLayout>
			<LinearLayout
					android:orientation="vertical"
					android:layout_width="fill_parent"
					android:layout_height="0dp" android:layout_weight="20">
			</LinearLayout>
		</LinearLayout>
		<LinearLayout
				android:orientation="vertical"
				android:layout_width="0dp"
				android:layout_height="fill_parent" android:layout_weight="15">
		</LinearLayout>
	</LinearLayout>
</RelativeLayout>