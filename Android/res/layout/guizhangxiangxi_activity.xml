<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent"
              android:background="@color/white" android:id="@+id/rlGuiZhangXiangXiBack">
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="95px" android:background="@drawable/bluebutton" android:id="@+id/rlTop">
        <TextView
                android:layout_width="260px"
                android:layout_height="50px"
                android:text="@string/guizhangxinxi"
                android:id="@+id/lblGuiZhangXiangXi_Title" android:layout_centerVertical="true" android:layout_centerHorizontal="true"
                android:textColor="@color/white" android:textSize="@dimen/TitleFontSize"
                android:gravity="center_vertical|center_horizontal"/>
        <ImageView
                android:layout_width="52px"
                android:layout_height="52px"
                android:id="@+id/imgGuiZhangXiangXi_Back" android:layout_centerVertical="true" android:layout_alignParentLeft="true"
                android:layout_marginLeft="40px" android:scaleType="fitCenter" android:src="@drawable/leftarrowicon"/>
    </RelativeLayout>
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" android:layout_below="@+id/rlTop"
            android:layout_alignParentLeft="true" android:background="@drawable/mainback">
        <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" android:layout_alignParentTop="true"
                android:layout_alignParentLeft="true" android:layout_margin="25px"
                android:background="@drawable/roundgrayrect_layout">
            <TextView
                    android:layout_width="630px"
                    android:layout_height="80px"
                    android:id="@+id/lblTitle" android:layout_alignParentTop="true"
                    android:layout_centerHorizontal="true" android:layout_marginTop="20px" android:gravity="center"
                    android:ellipsize="end" android:singleLine="true" android:textColor="@color/darkgray"
                    android:textSize="@dimen/ButtonFontSize"/>
            <view android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  class="com.damytech.utils.NoZoomControllWebView" android:id="@+id/view"
                  android:layout_below="@+id/lblTitle"
                  android:layout_marginTop="20px" android:layout_alignRight="@+id/lblTitle"
                  android:layout_alignLeft="@+id/lblTitle" android:layout_alignParentBottom="true"
                  android:layout_marginBottom="20px"/>
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>

