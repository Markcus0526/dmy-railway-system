<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:background="@color/white" android:id="@+id/rlBack">
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="120px" android:background="@drawable/rectgrayrect_layout" android:id="@+id/relativeLayout1">
        <TextView
                android:layout_width="450px"
                android:layout_height="fill_parent"
                android:id="@+id/lblTitle" android:layout_alignParentTop="true" android:layout_alignParentLeft="true"
                android:layout_marginLeft="20px" android:textColor="@color/gray"
                android:textSize="@dimen/EditTextFontSize" android:gravity="center_vertical|left"
                android:singleLine="true" android:ellipsize="end"/>
        <TextView
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:id="@+id/lblDate" android:layout_alignTop="@+id/lblTitle"
                android:layout_toRightOf="@+id/lblTitle"
                android:layout_alignBottom="@+id/lblTitle"
                android:gravity="center_vertical|right"
                android:textColor="@color/gray" android:textSize="@dimen/EditTextFontSize" android:singleLine="true"
                android:ellipsize="end" android:layout_marginRight="20px" android:layout_marginLeft="10px"/>
    </RelativeLayout>
</RelativeLayout>

