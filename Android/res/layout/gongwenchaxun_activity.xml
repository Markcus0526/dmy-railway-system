<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent"
              android:background="@color/white" android:id="@+id/rlGongWenChaXunBack">
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="95px" android:background="@drawable/bluebutton" android:id="@+id/rlTop">
        <TextView
                android:layout_width="260px"
                android:layout_height="50px"
                android:text="@string/gongwenchaxun"
                android:id="@+id/lblGongWenChaXun_Title" android:layout_centerVertical="true" android:layout_centerHorizontal="true"
                android:textColor="@color/white" android:textSize="@dimen/TitleFontSize"
                android:gravity="center_vertical|center_horizontal"/>
        <ImageView
                android:layout_width="52px"
                android:layout_height="52px"
                android:id="@+id/imgGongWenChaXun_Back" android:layout_centerVertical="true" android:layout_alignParentLeft="true"
                android:layout_marginLeft="40px" android:scaleType="fitCenter" android:src="@drawable/leftarrowicon"/>
    </RelativeLayout>
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" android:id="@+id/relativeLayout1"
            android:layout_below="@+id/rlTop" android:layout_above="@+id/relativeLayout2"
            android:background="@drawable/mainback">
        <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="80px" android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true" android:layout_marginTop="25px" android:layout_marginLeft="40px"
                android:layout_marginRight="40px" android:background="@drawable/roundgrayrect_layout"
                android:id="@+id/relativeLayout3">
            <ImageView
                    android:layout_width="44px"
                    android:layout_height="44px"
                    android:id="@+id/imgGongWenChaXun_ChaXun" android:layout_centerVertical="true"
                    android:layout_alignParentLeft="true" android:layout_marginLeft="18px"
                    android:scaleType="fitCenter" android:src="@drawable/searchicon"/>
            <EditText
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:id="@+id/txtGongWenChaXun_ChaXunWenZi" android:layout_alignParentTop="true"
                    android:layout_toRightOf="@+id/imgGongWenChaXun_ChaXun" android:layout_marginLeft="25px"
                    android:layout_alignParentRight="true" android:layout_marginRight="25px"
                    android:background="@android:color/transparent" android:gravity="center_vertical|left"
                    android:singleLine="true" android:textColor="@color/gray"
                    android:textSize="@dimen/EditTextFontSize"/>
        </RelativeLayout>
        <TextView
                android:layout_width="180px"
                android:layout_height="80px"
                android:text="@string/qishiriqi"
                android:id="@+id/lblGongWenChaXun_QiShiRiQi" android:layout_below="@+id/relativeLayout3"
                android:layout_alignLeft="@+id/relativeLayout3" android:layout_marginTop="30px" android:gravity="center_vertical|left"
                android:textColor="@color/gray" android:textSize="@dimen/EditTextFontSize"/>
        <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" android:layout_alignTop="@+id/lblGongWenChaXun_QiShiRiQi"
                android:layout_toRightOf="@+id/lblGongWenChaXun_QiShiRiQi"
                android:layout_alignBottom="@+id/lblGongWenChaXun_QiShiRiQi"
                android:layout_alignRight="@+id/relativeLayout3" android:background="@drawable/calendarbar"
                android:id="@+id/relativeLayout4">
            <ImageView
                    android:layout_width="44px"
                    android:layout_height="44px"
                    android:id="@+id/imgGongWenChaXun_QiShiRiQiMark" android:layout_centerVertical="true"
                    android:layout_alignParentLeft="true" android:layout_marginLeft="18px"
                    android:scaleType="fitCenter" android:src="@drawable/calendaricon"/>
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:id="@+id/lblGongWenChaXun_QiShiRiQiVal" android:layout_alignParentTop="true"
                    android:layout_toRightOf="@+id/imgGongWenChaXun_QiShiRiQiMark" android:layout_marginLeft="25px"
                    android:layout_alignParentRight="true" android:layout_marginRight="25px" android:gravity="center"
                    android:textColor="@color/white" android:textSize="@dimen/EditTextFontSize"
                    android:text="2014-07-29"/>
        </RelativeLayout>
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="80px"
                android:text="@string/jieshuriqi"
                android:id="@+id/lblGongWenChaXun_JieShuRiQi" android:layout_below="@+id/lblGongWenChaXun_QiShiRiQi"
                android:layout_alignLeft="@+id/lblGongWenChaXun_QiShiRiQi" android:layout_marginTop="30px"
                android:layout_toLeftOf="@+id/relativeLayout4" android:gravity="center_vertical|left"
                android:textColor="@color/gray" android:textSize="@dimen/EditTextFontSize"/>
        <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" android:layout_alignTop="@+id/lblGongWenChaXun_JieShuRiQi"
                android:layout_toRightOf="@+id/lblGongWenChaXun_JieShuRiQi"
                android:layout_alignBottom="@+id/lblGongWenChaXun_JieShuRiQi"
                android:layout_alignRight="@+id/relativeLayout3" android:background="@drawable/calendarbar"
                android:id="@+id/relativeLayout5">
            <ImageView
                    android:layout_width="44px"
                    android:layout_height="44px"
                    android:id="@+id/imgGongWenChaXun_JieShuRiQiMark" android:layout_centerVertical="true"
                    android:layout_alignParentLeft="true" android:layout_marginLeft="18px"
                    android:scaleType="fitCenter" android:src="@drawable/calendaricon"/>
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:id="@+id/lblGongWenChaXun_JieShuRiQiVal" android:layout_alignParentTop="true"
                    android:layout_toRightOf="@+id/imgGongWenChaXun_JieShuRiQiMark" android:layout_marginLeft="25px"
                    android:layout_alignParentRight="true" android:layout_marginRight="25px" android:gravity="center"
                    android:textColor="@color/white" android:textSize="@dimen/EditTextFontSize"
                    android:text="2014-07-29"/>
        </RelativeLayout>
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="80px"
                android:text="@string/fabubumen"
                android:id="@+id/lblGongWenChaXun_FaBuBuMen" android:layout_below="@+id/lblGongWenChaXun_JieShuRiQi"
                android:layout_alignLeft="@+id/lblGongWenChaXun_JieShuRiQi" android:layout_marginTop="30px"
                android:layout_toLeftOf="@+id/relativeLayout5" android:gravity="center_vertical|left"
                android:textColor="@color/gray" android:textSize="@dimen/EditTextFontSize"/>
        <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" android:layout_alignTop="@+id/lblGongWenChaXun_FaBuBuMen"
                android:layout_toRightOf="@+id/lblGongWenChaXun_FaBuBuMen"
                android:layout_alignBottom="@+id/lblGongWenChaXun_FaBuBuMen"
                android:layout_alignRight="@+id/relativeLayout3" android:background="@drawable/roundgrayrect_layout"
                android:id="@+id/relativeLayout6">
            <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:id="@+id/lblGongWenChaXun_FaBuBuMenVal" android:layout_centerVertical="true"
                    android:layout_alignParentLeft="true" android:layout_marginLeft="40px"
                    android:layout_marginRight="80px" android:gravity="center_vertical|left"
                    android:textColor="@color/gray" android:textSize="@dimen/EditTextFontSize"/>
            <ImageView
                    android:layout_width="80px"
                    android:layout_height="fill_parent"
                    android:id="@+id/imgGongWenChaXun_FaBuBuMen" android:layout_centerVertical="true"
                    android:layout_alignParentRight="true" android:scaleType="fitXY"
                    android:src="@drawable/spinexpandicon"/>
        </RelativeLayout>
        <Button
                android:layout_width="wrap_content"
                android:layout_height="80px"
                android:text="@string/chakan"
                android:id="@+id/btnGongWenChaXun_ChaXun" android:layout_below="@+id/lblGongWenChaXun_FaBuBuMen"
                android:layout_alignLeft="@+id/lblGongWenChaXun_FaBuBuMen" android:layout_marginTop="60px"
                android:layout_alignRight="@+id/relativeLayout6" android:background="@drawable/roundbluerect_layout"
                android:textColor="@color/lightblue" android:textSize="@dimen/ButtonFontSize"/>
    </RelativeLayout>
    <RelativeLayout
            android:id="@+id/relativeLayout2"
            android:layout_width="fill_parent"
            android:layout_height="100px" android:layout_alignParentBottom="true">
        <RelativeLayout
                android:layout_width="180px"
                android:layout_height="fill_parent" android:background="@drawable/graybutton"
                android:id="@+id/rlGongWenChaXun_DaiQian">
            <ImageView
                    android:layout_width="40px"
                    android:layout_height="40px"
                    android:id="@+id/imgGongWenChaXun_DaiQian"
                    android:scaleType="fitCenter" android:src="@drawable/gongwendaiqian_unselect"
                    android:layout_centerHorizontal="true" android:layout_marginTop="10px"/>
            <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:text="@string/gongwendaiqian"
                    android:id="@+id/lblGongWenChaXun_DaiQian" android:layout_centerVertical="true"
                    android:textSize="@dimen/EditTextFontSize" android:textColor="@color/gray"
                    android:gravity="center" android:layout_below="@+id/imgGongWenChaXun_DaiQian"/>
        </RelativeLayout>
        <RelativeLayout
                android:layout_width="180px"
                android:layout_height="fill_parent"
                android:layout_toRightOf="@+id/rlGongWenChaXun_DaiQian" android:background="@drawable/graybutton"
                android:layout_centerInParent="true" android:id="@+id/rlGongWenChaXun_FaBu">
            <ImageView
                    android:layout_width="40px"
                    android:layout_height="40px"
                    android:id="@+id/imgGongWenChaXun_FaBu"
                    android:scaleType="fitCenter" android:src="@drawable/gongwenfabu_unselect"
                    android:layout_centerHorizontal="true" android:layout_marginTop="10px"/>
            <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:text="@string/gongwenfabu"
                    android:id="@+id/lblGongWenChaXun_FaBu" android:layout_centerVertical="true"
                    android:gravity="center" android:textColor="@color/gray"
                    android:textSize="@dimen/EditTextFontSize" android:layout_below="@+id/imgGongWenChaXun_FaBu"/>
        </RelativeLayout>
        <RelativeLayout
                android:layout_width="180px"
                android:layout_height="fill_parent" android:layout_centerVertical="true"
                android:background="@drawable/graybutton"
                android:id="@+id/rlGongWenChaXun_YiShou" android:layout_toRightOf="@+id/rlGongWenChaXun_FaBu">
            <ImageView
                    android:layout_width="40px"
                    android:layout_height="40px"
                    android:id="@+id/imgGongWenChaXun_YiShou"
                    android:scaleType="fitCenter" android:src="@drawable/yishougongwen_unselect"
                    android:layout_marginTop="10px" android:layout_centerHorizontal="true"/>
            <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:text="@string/yishougongwen"
                    android:id="@+id/lblGongWenChaXun_YiShou" android:layout_centerVertical="true"
                    android:gravity="center"
                    android:textSize="@dimen/EditTextFontSize" android:textColor="@color/gray"
                    android:layout_below="@+id/imgGongWenChaXun_YiShou"/>
        </RelativeLayout>
        <RelativeLayout
                android:layout_width="180px"
                android:layout_height="fill_parent" android:layout_centerVertical="true"
                android:layout_alignParentRight="true" android:background="@drawable/graybutton"
                android:id="@+id/rlGongWenChaXun_ChaXun">
            <ImageView
                    android:layout_width="40px"
                    android:layout_height="40px"
                    android:id="@+id/imgGongWenChaXun_ChaXun"
                    android:scaleType="fitCenter" android:src="@drawable/gongwenchaxun_select"
                    android:layout_marginTop="10px" android:layout_centerHorizontal="true"/>
            <TextView
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:text="@string/gongwenchaxun"
                    android:id="@+id/lblGongWenChaXun_ChaXun" android:layout_centerVertical="true"
                    android:gravity="center"
                    android:textSize="@dimen/EditTextFontSize" android:textColor="@color/lightblue"
                    android:layout_below="@+id/imgGongWenChaXun_ChaXun"/>
        </RelativeLayout>
    </RelativeLayout>
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" android:id="@+id/rlGongWenChaXun_List"
            android:visibility="gone" android:clickable="true" android:background="@android:color/transparent">
        <ListView
                android:layout_width="400px"
                android:layout_height="720px"
                android:id="@+id/listGongWenChaXun_List" android:layout_centerInParent="true" android:background="@color/gray"/>
    </RelativeLayout>
</RelativeLayout>

