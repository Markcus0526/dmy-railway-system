<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent"
              android:background="@color/white" android:id="@+id/rlYouJianZhuanFaBack" android:longClickable="false">
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="95px" android:background="@drawable/bluebutton" android:id="@+id/rlTop">
        <TextView
                android:layout_width="260px"
                android:layout_height="50px"
                android:text="@string/zhuanfa"
                android:id="@+id/lblYouJianZhuanFaTitle" android:layout_centerVertical="true" android:layout_centerHorizontal="true"
                android:textColor="@color/white" android:textSize="@dimen/TitleFontSize"
                android:gravity="center_vertical|center_horizontal"/>
        <ImageView
                android:layout_width="52px"
                android:layout_height="52px"
                android:id="@+id/imgBack" android:layout_centerVertical="true" android:layout_alignParentLeft="true"
                android:layout_marginLeft="40px" android:scaleType="fitCenter" android:src="@drawable/leftarrowicon"/>
        <TextView
                android:layout_width="100px"
                android:layout_height="fill_parent"
                android:text="@string/fasong"
                android:id="@+id/lblSend" android:layout_centerVertical="true" android:layout_alignParentRight="true"
                android:textColor="@color/white" android:textSize="@dimen/EditTextFontSize"
                android:layout_marginRight="10px" android:gravity="center"/>
    </RelativeLayout>
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_alignParentLeft="true" android:background="@drawable/roundgrayrect_layout"
            android:layout_below="@+id/rlTop" android:layout_margin="30px">
        <ScrollView
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:id="@+id/scrollView">
            <RelativeLayout
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent">
                <TextView
                        android:layout_width="150px"
                        android:layout_height="80px"
                        android:id="@+id/lblReceiver" android:layout_alignParentTop="true"
                        android:layout_marginLeft="20px" android:gravity="center_vertical|left"
                        android:textColor="@color/gray" android:textSize="@dimen/EditTextFontSize" android:singleLine="true"
                        android:ellipsize="end" android:layout_alignParentLeft="true" android:text="@string/shoujianren"/>
                <RelativeLayout
                        android:layout_width="fill_parent"
                        android:layout_height="1px" android:layout_below="@+id/txtReceiver"
                        android:layout_centerHorizontal="true" android:background="@color/gray"
                        android:id="@+id/relativeLayout2">
                </RelativeLayout>
                <TextView
                        android:layout_width="fill_parent"
                        android:layout_height="80px"
                        android:id="@+id/lblTitle" android:layout_below="@+id/relativeLayout2"
                        android:layout_marginLeft="20px"
                        android:gravity="center_vertical|left"
                        android:textColor="@color/gray" android:textSize="@dimen/EditTextFontSize"
                        android:layout_toLeftOf="@+id/txtReceiver" android:text="@string/biaoti1"/>
                <RelativeLayout
                        android:layout_width="fill_parent"
                        android:layout_height="1px" android:layout_below="@+id/lblTitle"
                        android:layout_centerHorizontal="true" android:background="@color/gray"
                        android:id="@+id/relativeLayout3">
                </RelativeLayout>
                <TextView
                        android:layout_width="400px"
                        android:layout_height="80px"
                        android:id="@+id/lblFileName" android:layout_below="@+id/relativeLayout3"
                        android:layout_alignLeft="@+id/lblTitle" android:gravity="center_vertical|left"
                        android:textColor="@color/gray" android:textSize="@dimen/EditTextFontSize" android:ellipsize="end"
                        android:singleLine="true" android:text="@string/fujian"/>
                <Button
                        android:layout_width="200px"
                        android:layout_height="60px"
                        android:text="@string/tianjiafujian"
                        android:id="@+id/btnAddFile" android:layout_below="@+id/relativeLayout3"
                        android:layout_marginTop="10px"
                        android:textSize="@dimen/EditTextFontSize" android:textColor="@color/lightblue"
                        android:background="@drawable/roundbluerect_layout"
                        android:layout_alignParentRight="true" android:layout_marginRight="20px"/>
                <RelativeLayout
                        android:layout_width="fill_parent"
                        android:layout_height="1px"
                        android:background="@color/gray" android:id="@+id/relativeLayout4"
                        android:layout_below="@+id/lblFileName">
                </RelativeLayout>
                <TextView
                        android:layout_width="fill_parent"
                        android:layout_height="80px"
                        android:id="@+id/lblContent" android:layout_below="@+id/relativeLayout4"
                        android:layout_centerHorizontal="true" android:layout_marginLeft="20px"
                        android:layout_marginRight="20px" android:gravity="center_vertical|left"
                        android:textColor="@color/gray" android:textSize="@dimen/EditTextFontSize"
                        android:text="@string/faziyouxiang"/>
                <EditText
                        android:layout_width="350px"
                        android:layout_height="wrap_content"
                        android:id="@+id/txtReceiver" android:layout_alignParentTop="true"
                        android:layout_toRightOf="@+id/lblReceiver" android:layout_marginLeft="10px" android:gravity="left|top"
                        android:textColor="@color/gray" android:textSize="@dimen/EditTextFontSize"
                        android:background="@android:color/transparent"
                        android:minHeight="80px" android:enabled="false" android:paddingTop="20px"/>
                <ImageView
                        android:layout_width="54px"
                        android:layout_height="44px"
                        android:id="@+id/imgAddUser"
                        android:layout_alignParentRight="true" android:layout_alignParentTop="true"
                        android:layout_marginTop="15px" android:layout_marginRight="20px" android:scaleType="fitCenter"
                        android:src="@drawable/adduser"/>
                <EditText
                        android:layout_width="wrap_content"
                        android:layout_height="80px"
                        android:id="@+id/txtTitle" android:layout_below="@+id/txtReceiver"
                        android:layout_alignLeft="@+id/txtReceiver" android:layout_alignRight="@+id/imgAddUser"
                        android:ellipsize="end" android:gravity="center_vertical|left"
                        android:background="@android:color/transparent" android:textColor="@color/gray"
                        android:textSize="@dimen/EditTextFontSize"/>
                <EditText
                        android:layout_width="wrap_content"
                        android:layout_height="fill_parent"
                        android:inputType="textMultiLine"
                        android:ems="10"
                        android:id="@+id/txtContent" android:layout_below="@+id/lblContent"
                        android:layout_alignLeft="@+id/lblContent" android:layout_alignRight="@+id/lblContent"
                        android:layout_alignParentBottom="true" android:layout_marginBottom="20px" android:gravity="left|top"
                        android:textColor="@color/gray" android:textSize="@dimen/EditTextFontSize" android:padding="10px"
                        android:background="@android:color/transparent" android:minHeight="400px"/>
            </RelativeLayout>
        </ScrollView>
    </RelativeLayout>
</RelativeLayout>

